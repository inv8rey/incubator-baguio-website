# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings > API in the Supabase dashboard).
# Run supabase/schema.sql in the Supabase SQL editor first.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog project API key + host (Project Settings > Project API key in PostHog).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Cloudflare Workers AI (Account Home > right sidebar for Account ID;
# My Profile > API Tokens for a token with Workers AI edit access).
# Server-side only — never expose these with a NEXT_PUBLIC_ prefix.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Shared secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET`
# when it hits /api/ai-insights/cron on its daily 7:30am schedule (see
# vercel.json). Generate any random string, e.g. `openssl rand -hex 24`.
CRON_SECRET=
